# PayGuard Backend Configuration

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# Squad API (Sandbox - for testing)
# Get credentials from https://dashboard.sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=your-squad-secret-key-here

# Optional: For production
# SQUAD_API_URL=https://api-live.squadco.com (live endpoint)
# SQUAD_LIVE_SECRET_KEY=your-live-secret-key
